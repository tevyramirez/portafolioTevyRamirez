# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# large 3D assets / untracked source folders
/white-rabbit*
/public/models/rabbit/
# Agent tools
.agents/
.antigravitycli/
conductor/
skills-lock.json
design-state.md
data/*.json

# Excepción: documentos de marca (brand kit + templates) se versionan
